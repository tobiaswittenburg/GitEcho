{
  "name": "gitecho",
  "type": "module",
  "version": "0.2.9",
  "description": "GitHub/Azure DevOps repository backup tool",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node build-worker.mjs",
    "preview": "astro preview",
    "start": "node dist/server/entry.mjs",
    "worker": "node dist/worker/index.mjs",
    "worker:dev": "npx tsx worker/index.ts",
    "seed:demo": "tsx --env-file=.env.demo scripts/seed-demo.ts",
    "screenshots": "playwright test --config=playwright.docs.config.ts",
    "docs:demo": "npm run seed:demo && npm run screenshots"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/node": "^10.0.6",
    "@popperjs/core": "^2.11.8",
    "admin-lte": "^4.0.0-rc7",
    "archiver": "^7.0.1",
    "astro": "^6.1.9",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "cronstrue": "^3.14.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bootstrap": "^5.2.10",
    "@types/node": "^22.19.19",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "yaml": "^2.8.3"
  }
}
